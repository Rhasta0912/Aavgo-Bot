DISCORD_TOKEN=

# Hours API v1 is disabled until all three values are explicitly configured.
AAVGO_HOURS_API_V1_ENABLED=false
AAVGO_HOURS_API_V1_URL=https://partner.example.com/api/aavgo/hours/v1/snapshots
AAVGO_HOURS_API_V1_SECRET=replace-with-a-random-shared-secret-of-at-least-32-characters
AAVGO_HOURS_API_V1_INTERVAL_MS=900000
AAVGO_HOURS_API_V1_TIMEOUT_MS=10000

# Inbound API: use the assigned SparkedHost port, never a port outside your allocation.
AAVGO_HOURS_API_V1_INBOUND_ENABLED=false
AAVGO_HOURS_API_V1_PORT=25913
# Keep false for a raw IP:port. Set true only when a trusted HTTPS proxy forwards to this port.
AAVGO_HOURS_API_V1_INBOUND_ALLOW_HTTP=false
AAVGO_HOURS_API_V1_READ_TOKEN=replace-with-a-random-read-token-of-at-least-32-characters
# Keep hour corrections disabled unless you intentionally need signed external changes.
AAVGO_HOURS_API_V1_WRITE_ENABLED=false
AAVGO_HOURS_API_V1_WRITE_SECRET=replace-with-a-different-random-write-secret-of-at-least-32-characters
